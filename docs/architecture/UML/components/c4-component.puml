@startuml akdb-components
title ArchitecturalKnowledgeDB - Service Components
package "Authoring and architecture" {
 component SadService
 component UMLService
 component KnowledgeService
 component AuthoringService
 component CompletenessService
}
package "Retrieval and reasoning" {
 component SearchService
 component ContextService
 component CognitionService
 component ReasoningService
 component MemoryService
 component RecallBackend
}
package "Governance and provenance" {
 component ProjectService
 component RepositoryService
 component GitScannerService
 component ConsistencyService
 component StalenessService
 component GuardrailService
 component ReviewService
 component SurveyService
 component OriginService
}
package "Pipelines" {
 component ImportExportService
 component ExportTargetsService
 component "ExportFlush" as ExportFlush
 component ReingestService
 component RoadmapService
 component SetupService
}
component "Database facade" as DB
SadService --> KnowledgeService
ImportExportService --> SadService
ImportExportService --> UMLService
ImportExportService --> ExportTargetsService : sync / verify / incremental
KnowledgeService --> ExportFlush : notify canonical body write
ExportFlush --> ExportTargetsService : durable dirty target
ExportFlush --> DB : register commit callback
DB --> ExportFlush : after commit / rollback
ExportFlush --> ImportExportService : post-commit incremental flush
ExportTargetsService --> DB
AuthoringService --> KnowledgeService
CompletenessService --> KnowledgeService
ContextService --> SearchService
CognitionService --> KnowledgeService
ReasoningService --> KnowledgeService
RecallBackend --> SearchService
GitScannerService --> RepositoryService
ReingestService --> ImportExportService
ReingestService --> GitScannerService
KnowledgeService --> DB
UMLService --> DB
SearchService --> DB
MemoryService --> DB
ProjectService --> DB
@enduml
