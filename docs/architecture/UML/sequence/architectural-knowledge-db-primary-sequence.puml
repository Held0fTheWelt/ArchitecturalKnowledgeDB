@startuml akdb-primary-sequence
title ArchitecturalKnowledgeDB - Authoring and Recall
actor Maintainer
actor Agent
participant "CLI / API / MCP" as Surface
participant SadService
participant UMLService
participant ContextService
participant ImportExportService as Exporter
database "Database facade" as DB
participant "docs/architecture projection" as Files
Maintainer -> Surface : upsert SAD document/section/decision
Surface -> SadService : validated authoring request
SadService -> DB : canonical akdb:// knowledge items
Maintainer -> Surface : create/update UML
Surface -> UMLService : validated diagram model/source
UMLService -> DB : canonical diagram + graph
Maintainer -> Surface : export SAD
Surface -> Exporter : export project documents
Exporter -> DB : read SAD/UML aggregate
Exporter -> Files : write deterministic projection
Agent -> Surface : search/context/recall
Surface -> ContextService : authority-aware query
ContextService -> DB : FTS/links/provenance
ContextService --> Agent : compact grounded context
@enduml
